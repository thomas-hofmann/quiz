{% extends 'base.html.twig' %}
{% block title %}Frage bearbeiten{% endblock %}
{% block content %}
<div class="container container--fade-in">
    <div class="box box--70 border rounded shadow p-3 mx-auto">
        <h1>Frage bearbeiten</h1>
        {% if minCorrectError %}
            <p class="text-danger"><i class="fa-solid fa-circle-exclamation"></i> Es muss mindestens eine Antwort richtig sein!</p>
        {% endif %}
        {% if answerContentError|default(false) %}
            <p class="text-danger"><i class="fa-solid fa-circle-exclamation"></i> Jede Antwort braucht mindestens Text oder Bild-Link.</p>
        {% endif %}
        <form action="{{ path('update_question') }}" method="post">
            <div class="form-group">
                <label for="question">Fragetext</label>
                <input type="hidden" name="questionId" value="{{ question.id }}">
                <textarea type="text" class="form-control" id="question" name="question" rows="3" required>{{ question.text }}</textarea>
                {% for answer in question.getAnswers %}
                    {% set index = loop.index0 + 1%}
                   <label for="answer1" class="mt-2">Antwort: {{ index }}</label>
                   <input type="hidden" name="answerId{{ index }}" value="{{ answer.id }}">
                    <div class="input-group mb-3">
                        <div class="input-group-text">
                            <small class="pe-2">Richtig</small>
                            <input class="form-check-input quiz__edit-checkbox mt-0" id="answer{{ index }}-correct" name="answer{{ index }}-correct" type="checkbox" value="1"{% if answer.isCorrect %} checked {% endif %}>
                        </div>
                        <textarea type="text" class="form-control" id="answer{{ index }}" name="answer{{ index }}">{{ answer.text }}</textarea>
                    </div>
                    <div class="mb-3">
                        <label for="answer{{ index }}-image" class="form-label">Bild-Link zu Antwort {{ index }} (optional)</label>
                        <input class="form-control" type="url" id="answer{{ index }}-image" name="answer{{ index }}-image" maxlength="2048" placeholder="https://cdn.example.com/answer-{{ index }}.jpg" value="{{ answer.image }}">
                        {% if answer.image %}
                            {% set imageSrc = answer.image starts with 'http' ? answer.image : asset(answer.image) %}
                            <img src="{{ imageSrc }}" alt="Antwortbild {{ index }}" class="img-fluid rounded mt-2" style="max-height: 120px;">
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            <p class="mt-3">
                <button type="submit" class="btn btn-success bg-gradient mt-2"><i class="fa-solid fa-arrows-rotate"></i> Diese Frage aktualisiere</button>
                <a href="{{ path('edit_quiz', { 'id': question.quiz.id }) }}" class="btn btn-secondary bg-gradient mt-2"><i class="fa-regular fa-circle-question"></i> Zurück zum Quiz</a>
            </p>
        </form>
    </div>
</div>
{% endblock %}
