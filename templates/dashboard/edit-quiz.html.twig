{% extends 'base.html.twig' %}
{% block title %}Quiz bearbeiten{% endblock %}
{% block content %}
<div class="container quiz-edit-container" data-aos="zoom-in">
    <div class="box box--70 border rounded shadow p-3 mx-auto">
        <h1>Quiz bearbeiten</h1>
         {% if questions|length == 0 %}
            <p class="text-danger fw-bold">Das Quiz hat noch keine Fragen.</p>
        {% endif %}
        <form action="{{ path('update_quiz') }}" method="get">
            <div class="form-group">
                <input type="hidden" name="quizId" value="{{ quiz.id }}">
                <label for="quizName">Name</label>
                <input type="text" class="form-control" id="quizName" name="quizName" value="{{ quiz.name }}" required>
                <label for="quizcode" class="mt-2">Beitrittscode</label>
                <input type="text" class="form-control {% if error %}is-invalid{% endif %}" id="quizcode" name="quizCode" value="{{ quiz.code }}" required>
                 {% if error %}
                    <div id="quizcode" class="invalid-feedback">
                        Achtung Code wird bereits verwendet. Nutzen Sie einen anderen
                    </div>
                {% endif %}
                {% if user.categories | length > 0 %}
                    <label for="category" class="mt-2">Ordner</label>
                    <select class="form-select" id="category" name="category">
                        <option value="" disabled {% if not quiz.category %}selected{% endif %}>Bitte wählen</option>
                        <option value="no-category">Keinen Ordner</option>
                        {% for category in user.categories %}
                            <option value="{{ category.id }}" {% if quiz.category and quiz.category.id == category.id %}selected{% endif %}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                {% endif %}
                <p class="mb-2 mt-2 fw-bold">Weitere Optionen</p>
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="leaderboard-check" name="without-leaderboard" value="true" {% if quiz.isWithoutLeaderboard %}checked{% endif %}>
                    <label class="form-check-label" for="leaderboard-check">Ohne Rangliste</label>
                </div>
            </div>
            <p class="mt-3">
                <button type="submit" class="btn btn-success bg-gradient mt-2"><i class="fa-regular fa-floppy-disk"></i> Werte aktualisieren</button>
            </p>
        </form>
        {% if questions|length %}
            <h2>Fragen bearbeiten</h2>
            <p>
                <span><i class="fa-solid fa-circle-info"></i> Die Reihenfolge der Fragen kann durch Drag-and-Drop geändert werden.</span><br>
                <span><i class="fa-solid fa-circle-info"></i> Danach auf "Sortierung aktualisieren" klicken.</span>
            </p>
            <ul class="list-group mb-2" id="sortable">
                {% for question in questions %}
                    <li class="list-group-item edit-question-list-item" data-id="{{ question.id }}">
                        <p class="mb-2 fw-bold">
                            {{ loop.index }}. {{ question.text}}
                        </p>
                        <div class="row">
                            <div class="col-12 col-md-8">
                                <ul class="list-group mb-2 dashboard__quiz-answer-list">
                                    {% for answer in question.getAnswers %}
                                        <li class="list-group-item{% if answer.isCorrect %} list-group-item-success{% endif %}">
                                            {{ answer.text }}
                                            {% if answer.image %}
                                                {% set imageSrc = answer.image starts with 'http' ? answer.image : asset(answer.image) %}
                                                <div class="mt-2">
                                                    <img src="{{ imageSrc }}" alt="Antwortbild" class="img-fluid rounded" style="max-height: 120px;">
                                                </div>
                                            {% endif %}
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                            <div class="col-12 col-md-4">
                                <a href="{{ path('edit_question', { 'id': question.id }) }}" class="d-block btn btn-sm btn-dark bg-gradient"><i class="fa-regular fa-pen-to-square"></i> Frage bearbeiten</a>
                                <a href="{{ path('delete_question', { 'id': question.id }) }}" class="d-block btn btn-sm btn-danger bg-gradient mt-2" onclick="return confirm('Sind Sie sicher, dass Sie diese Frage löschen möchten?')"><i class="fa-regular fa-trash-can"></i> Frage löschen</a>
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
            <p>
                <button class="btn btn-success bg-gradient mt-2" id="save-order"><i class="fa-regular fa-floppy-disk"></i> Sortierung aktualisieren</button>
            </p>
        {% endif %}
        {% if questions|length %}
            <h3>Weitere Frage erstellen</h3>
        {% else %}
            <h3>Frage erstellen</h3>
        {% endif %}
        <p>
            <small><i class="fa-solid fa-circle-info"></i> Richtige Antwort bitte markieren. Es muss mindestens eine Antwort richtig sein.</small><br>
            <small><i class="fa-solid fa-circle-info"></i> Es müssen stets genau vier Antworten vorhanden sein.</small><br>
            <small><i class="fa-solid fa-circle-info"></i> Es muss immer ein Text <u>oder</u> Bild eingetragen werden.</small>
        </p>
        {% set errorBorder = '' %}
        {% if minCorrectError %}
            <p class="text-danger"><i class="fa-solid fa-circle-exclamation"></i> Es muss mindestens eine Antwort richtig sein! Frage wurde nicht hinzugefügt.</p>
            {% set errorBorder = 'is-invalid' %}
        {% endif %}
        {% if answerContentError|default(false) %}
            <p class="text-danger"><i class="fa-solid fa-circle-exclamation"></i> Jede Antwort braucht mindestens Text oder Bild-Link.</p>
        {% endif %}
        <form action="{{ path('update_questions') }}" method="post">
            <div class="form-group">
                <input type="hidden" name="quizId" value="{{ quiz.id }}">
                <label for="question" class="fw-bold">Fragetext</label>
                {% if app.request.request.has('question') %}
                    {% set questionText = app.request.request.get('question') %}
                {% elseif app.request.query.has('question') %}
                    {% set questionText = app.request.query.get('question') %}
                {% endif %}
                <textarea class="form-control" id="question" name="question" rows="3" required>{% if questionText is defined %}{{ questionText }}{% endif %}</textarea>
                <label for="answer1" class="mt-2 fw-bold">Antwort: A</label>
                <div class="quiz__answer-row mb-2">
                    {% if app.request.request.has('answer1') %}
                        {% set answerText1 = app.request.request.get('answer1') %}
                    {% elseif app.request.query.has('answer1') %}
                        {% set answerText1 = app.request.query.get('answer1') %}
                    {% endif %}
                    <textarea class="form-control quiz__answer-textarea" id="answer1" name="answer1">{% if answerText1 is defined %}{{ answerText1 }}{% endif %}</textarea>
                    <div class="quiz__correct-box">
                        <label class="mb-0 d-flex align-items-center justify-content-between gap-2" for="answer1-correct">
                            <span class="small fw-bold">Richtig</span>
                            <input class="form-check-input quiz__edit-checkbox mt-0 {{ errorBorder }}" id="answer1-correct" name="answer1-correct" type="checkbox" value="1" aria-label="Antwort A ist richtig">
                        </label>
                    </div>
                </div>
                <div class="mb-2 quiz__image-link-wrapper">
                    <label for="answer1-image" class="form-label small text-muted mb-1">Bild-Link (optional)</label>
                    {% if app.request.request.has('answer1-image') %}
                        {% set answerImage1 = app.request.request.get('answer1-image') %}
                    {% elseif app.request.query.has('answer1-image') %}
                        {% set answerImage1 = app.request.query.get('answer1-image') %}
                    {% endif %}
                    <input class="form-control form-control-sm quiz__image-link-input" type="url" id="answer1-image" name="answer1-image" maxlength="2048" placeholder="https://cdn.example.com/answer-a.jpg" value="{% if answerImage1 is defined %}{{ answerImage1 }}{% endif %}">
                </div>
                <label for="answer2" class="mt-2 fw-bold">Antwort: B</label>
                <div class="quiz__answer-row mb-2">
                    {% if app.request.request.has('answer2') %}
                        {% set answerText2 = app.request.request.get('answer2') %}
                    {% elseif app.request.query.has('answer2') %}
                        {% set answerText2 = app.request.query.get('answer2') %}
                    {% endif %}
                    <textarea class="form-control quiz__answer-textarea" id="answer2" name="answer2">{% if answerText2 is defined %}{{ answerText2 }}{% endif %}</textarea>
                    <div class="quiz__correct-box">
                        <label class="mb-0 d-flex align-items-center justify-content-between gap-2" for="answer2-correct">
                            <span class="small fw-bold">Richtig</span>
                            <input class="form-check-input quiz__edit-checkbox mt-0 {{ errorBorder }}" id="answer2-correct" name="answer2-correct" type="checkbox" value="1" aria-label="Antwort B ist richtig">
                        </label>
                    </div>
                </div>
                <div class="mb-2 quiz__image-link-wrapper">
                    <label for="answer2-image" class="form-label small text-muted mb-1">Bild-Link (optional)</label>
                    {% if app.request.request.has('answer2-image') %}
                        {% set answerImage2 = app.request.request.get('answer2-image') %}
                    {% elseif app.request.query.has('answer2-image') %}
                        {% set answerImage2 = app.request.query.get('answer2-image') %}
                    {% endif %}
                    <input class="form-control form-control-sm quiz__image-link-input" type="url" id="answer2-image" name="answer2-image" maxlength="2048" placeholder="https://cdn.example.com/answer-b.jpg" value="{% if answerImage2 is defined %}{{ answerImage2 }}{% endif %}">
                </div>
                <label for="answer3" class="mt-2 fw-bold">Antwort: C</label>
                <div class="quiz__answer-row mb-2">
                    {% if app.request.request.has('answer3') %}
                        {% set answerText3 = app.request.request.get('answer3') %}
                    {% elseif app.request.query.has('answer3') %}
                        {% set answerText3 = app.request.query.get('answer3') %}
                    {% endif %}
                    <textarea class="form-control quiz__answer-textarea" id="answer3" name="answer3">{% if answerText3 is defined %}{{ answerText3 }}{% endif %}</textarea>
                    <div class="quiz__correct-box">
                        <label class="mb-0 d-flex align-items-center justify-content-between gap-2" for="answer3-correct">
                            <span class="small fw-bold">Richtig</span>
                            <input class="form-check-input quiz__edit-checkbox mt-0 {{ errorBorder }}" id="answer3-correct" name="answer3-correct" type="checkbox" value="1" aria-label="Antwort C ist richtig">
                        </label>
                    </div>
                </div>
                <div class="mb-2 quiz__image-link-wrapper">
                    <label for="answer3-image" class="form-label small text-muted mb-1">Bild-Link (optional)</label>
                    {% if app.request.request.has('answer3-image') %}
                        {% set answerImage3 = app.request.request.get('answer3-image') %}
                    {% elseif app.request.query.has('answer3-image') %}
                        {% set answerImage3 = app.request.query.get('answer3-image') %}
                    {% endif %}
                    <input class="form-control form-control-sm quiz__image-link-input" type="url" id="answer3-image" name="answer3-image" maxlength="2048" placeholder="https://cdn.example.com/answer-c.jpg" value="{% if answerImage3 is defined %}{{ answerImage3 }}{% endif %}">
                </div>
                <label for="answer4" class="mt-2 fw-bold">Antwort: D</label>
                <div class="quiz__answer-row mb-2">
                    {% if app.request.request.has('answer4') %}
                        {% set answerText4 = app.request.request.get('answer4') %}
                    {% elseif app.request.query.has('answer4') %}
                        {% set answerText4 = app.request.query.get('answer4') %}
                    {% endif %}
                    <textarea class="form-control quiz__answer-textarea" id="answer4" name="answer4">{% if answerText4 is defined %}{{ answerText4 }}{% endif %}</textarea>
                    <div class="quiz__correct-box">
                        <label class="mb-0 d-flex align-items-center justify-content-between gap-2" for="answer4-correct">
                            <span class="small fw-bold">Richtig</span>
                            <input class="form-check-input quiz__edit-checkbox mt-0 {{ errorBorder }}" id="answer4-correct" name="answer4-correct" type="checkbox" value="1" aria-label="Antwort D ist richtig">
                        </label>
                    </div>
                </div>
                <div class="mb-2 quiz__image-link-wrapper">
                    <label for="answer4-image" class="form-label small text-muted mb-1">Bild-Link (optional)</label>
                    {% if app.request.request.has('answer4-image') %}
                        {% set answerImage4 = app.request.request.get('answer4-image') %}
                    {% elseif app.request.query.has('answer4-image') %}
                        {% set answerImage4 = app.request.query.get('answer4-image') %}
                    {% endif %}
                    <input class="form-control form-control-sm quiz__image-link-input" type="url" id="answer4-image" name="answer4-image" maxlength="2048" placeholder="https://cdn.example.com/answer-d.jpg" value="{% if answerImage4 is defined %}{{ answerImage4 }}{% endif %}">
                </div>
            </div>
            <p class="mt-3">
                <button type="submit" class="btn btn-success bg-gradient mt-2"><i class="fa-solid fa-plus"></i> Diese Frage hinzufügen</button> 
            </p>
        </form>
        <hr>
        <a href="{{ path('dashboard')}}" class="btn btn-secondary bg-gradient mt-2"><i class="fa-solid fa-table-columns"></i> Zurück zum Dashboard</a>
    </div>
</div>
{% endblock %}
