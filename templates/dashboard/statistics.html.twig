{% extends 'base.html.twig' %}
{% block title %}Quiz auswerten{% endblock %}
{% block content %}
<div class="container text-center" data-aos="zoom-in">
    <div class="box box--70 border rounded shadow p-3 mx-auto position-relative">
        <h1 class="mb-0">{{ quiz.name }}</h1>
        <p class="text-primary position-absolute top-0 end-0 mt-2 me-3 fs-5"><i class="fa-solid fa-arrows-rotate fa-spin"></i> Live</p>
        <div class="form-check form-switch text-start">
            <input class="form-check-input float-none toggle-quiz" type="checkbox" id="quizToggle{{ quiz.id }}" 
                {% if quiz.isEnabled %} checked {% endif %} 
                data-url="{{ path('toggle_quiz', {id: quiz.id}) }}">
            <label class="form-check-label toggle-quiz-label" for="quizToggle{{ quiz.id }}">
                {% if quiz.isEnabled %}Quiz ist aktiviert{% else %} Quiz ist deaktiviert {% endif %}
            </label>
        </div>
        <div class="accordion mt-2" id="accordionExample">
            <div class="accordion-item">
                <h2 class="accordion-header" id="headingOne">
                    <button class="accordion-button collapsed p-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                        <span class="d-block w-100 text-center"><h4 class="m-0 ps-3 fw-bold"><i class="fa-solid fa-chart-simple"></i> Fragen auswerten</h4></span>
                    </button>
                </h2>
                <div id="collapseOne" class="accordion-collapse collapse border-top" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                    <div class="accordion-body">
                        <div class="form-check form-switch d-inline-flex align-items-center gap-2 mb-3">
                            <input
                                class="form-check-input m-0"
                                type="checkbox"
                                role="switch"
                                id="show-answers-toggle"
                            >
                            <label class="form-check-label" for="show-answers-toggle">Alle Ergebnisse</label>
                        </div>
                        <div id="answer-stats-container">
                            {% for question in quiz.getQuestions %}
                                {% set index = loop.index0 %}
                                <div id="question-stat-slot-{{ question.id }}" class="position-relative">
                                    <div class="form-check form-switch position-absolute top-0 start-0 mt-2 ms-2 z-1">
                                        <input
                                            data-href="{{ path('answer-stats-question', { 'quizId': quiz.id, 'questionId': question.id }) }}"
                                            data-target="#question-stat-slot-{{ question.id }}"
                                            class="form-check-input show-question-stats-button"
                                            type="checkbox"
                                            role="switch"
                                            title="Stats anzeigen"
                                            aria-label="Stats anzeigen"
                                        >
                                    </div>
                                    <div class="question-stat-content">
                                        <div class="question-stat-default">
                                            <div class="text-center border rounded bg-gradient p-2 mb-3">
                                                <h3>Frage {{ index + 1 }}</h3>
                                                {% if question.text|trim is not empty %}
                                                    <h4 class="mb-3 mt-3">{{ question.text }}</h4>
                                                {% endif %}
                                                {% if question.image %}
                                                    {% set questionImageSrc = versioned_image_url(question.image, quiz) %}
                                                    <img src="{{ questionImageSrc }}" alt="Fragebild {{ index + 1 }}" class="img-fluid rounded mb-2" style="max-height: 180px; width: auto; object-fit: contain;">
                                                {% endif %}
                                            </div>
                                            <ul class="list-group mb-3">
                                                <li class="list-group-item question-stats-li fs-5 pt-2 pb-2">
                                                    <span class="question__letter question__letter--statistics bg-dark text-light border">A</span>
                                                    {% if question.getAnswers.0.text|trim is not empty %}
                                                        {{ question.getAnswers.0.text }}
                                                    {% endif %}
                                                    {% if question.getAnswers.0.image %}
                                                        {% set imageSrcA = versioned_image_url(question.getAnswers.0.image, quiz) %}
                                                        <div class="{% if question.getAnswers.0.text|trim is not empty %}mt-2{% endif %}">
                                                            <img src="{{ imageSrcA }}" alt="Antwortbild A" class="img-fluid rounded" style="max-height: 140px; width: auto; object-fit: contain;">
                                                        </div>
                                                    {% endif %}
                                                </li>
                                                <li class="list-group-item question-stats-li fs-5 pt-2 pb-2">
                                                    <span class="question__letter question__letter--statistics bg-dark text-light border">B</span>
                                                    {% if question.getAnswers.1.text|trim is not empty %}
                                                        {{ question.getAnswers.1.text }}
                                                    {% endif %}
                                                    {% if question.getAnswers.1.image %}
                                                        {% set imageSrcB = versioned_image_url(question.getAnswers.1.image, quiz) %}
                                                        <div class="{% if question.getAnswers.1.text|trim is not empty %}mt-2{% endif %}">
                                                            <img src="{{ imageSrcB }}" alt="Antwortbild B" class="img-fluid rounded" style="max-height: 140px; width: auto; object-fit: contain;">
                                                        </div>
                                                    {% endif %}
                                                </li>
                                                <li class="list-group-item question-stats-li fs-5 pt-2 pb-2">
                                                    <span class="question__letter question__letter--statistics bg-dark text-light border">C</span>
                                                    {% if question.getAnswers.2.text|trim is not empty %}
                                                        {{ question.getAnswers.2.text }}
                                                    {% endif %}
                                                    {% if question.getAnswers.2.image %}
                                                        {% set imageSrcC = versioned_image_url(question.getAnswers.2.image, quiz) %}
                                                        <div class="{% if question.getAnswers.2.text|trim is not empty %}mt-2{% endif %}">
                                                            <img src="{{ imageSrcC }}" alt="Antwortbild C" class="img-fluid rounded" style="max-height: 140px; width: auto; object-fit: contain;">
                                                        </div>
                                                    {% endif %}
                                                </li>
                                                <li class="list-group-item question-stats-li fs-5 pt-2 pb-2">
                                                    <span class="question__letter question__letter--statistics bg-dark text-light border">D</span>
                                                    {% if question.getAnswers.3.text|trim is not empty %}
                                                        {{ question.getAnswers.3.text }}
                                                    {% endif %}
                                                    {% if question.getAnswers.3.image %}
                                                        {% set imageSrcD = versioned_image_url(question.getAnswers.3.image, quiz) %}
                                                        <div class="{% if question.getAnswers.3.text|trim is not empty %}mt-2{% endif %}">
                                                            <img src="{{ imageSrcD }}" alt="Antwortbild D" class="img-fluid rounded" style="max-height: 140px; width: auto; object-fit: contain;">
                                                        </div>
                                                    {% endif %}
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="question-stat-result d-none"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-3">
            {% if chartBar %}
                <div class="row statistics-chart-row" data-quiz="{{ quiz.id }}" id="chart-row">
                    <div class="col-12 col-md-6">
                        <ul class="list-group rounded">
                            <li class="list-group-item">
                                <h3>{{ quiz.code}}</h3>
                                <img class="border border-secondary-subtle mb-2" src="{{ qr_code_url(url('home', { 'quizcode': quiz.code })) }}" width="200" height="200" style="max-width: 100%; height: auto;">
                            </li>
                        </ul>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="border rounded statistics-chart-col">
                            {{ render_chart(chartBar, {'id': 'barChart'})  }}
                        </div>
                    </div>
                </div>
            {% endif %}
            <div id="container-stats">
                <ul class="list-group rounded mb-2">
                    <li class="list-group-item">
                        Teilnehmerzahl: <strong>{{ leaderBoardEntries|length }}</strong>
                    </li>
                    <li class="list-group-item">
                        Maximal erreichbare Punktzahl: <strong>{{ quiz.getQuestions|length }}</strong>
                    </li>
                    <li class="list-group-item border-bottom-0">
                        Punkteschnitt: <strong>{{ averageScore }}</strong>
                    </li>
                    <li class="fs-5 list-group-item border-0 p-0">
                        <div class="bg-gradient p-2 rounded-bottom
                            {% if averageScorePercentage >= 70 %}
                                bg-success-subtle text-success-emphasis border border-success
                            {% elseif averageScorePercentage >= 40 %}
                                bg-warning-subtle text-warning-emphasis border border-warning
                            {% else %}
                                bg-danger-subtle text-danger-emphasis border border-danger
                            {% endif %}
                        ">

                            <strong>Kursnote: {{ averageScorePercentage }}%</strong>
                        </div>
                    </li>
                </ul>
                {% if quiz.isWithoutLeaderboard == false %}
                    <table class="table table-striped table-dark leaderboard mb-0 mt-3" data-quiz="{{ quiz.id }}">
                        <thead>
                            <tr>
                            <th scope="col"><i class="fa-solid fa-ranking-star"></i></th>
                            <th scope="col" class="text-start">Spielername</th>
                            <th scope="col" ><i class="fa-regular fa-circle-check"></i></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set place = 1 %}
                            {% for entry in leaderBoardEntries %}
                                {% if loop.index == 1 %}
                                    {% set entryScoreTmp = entry.score %}
                                {% endif %}
                                {% if entryScoreTmp != entry.score %}
                                    {% set place = place + 1 %}
                                    {% set entryScoreTmp = entry.score %}
                                {% endif %}
                                <tr>
                                    {% if matrikelnummerHash %}
                                        <td {% if entry.hash == matrikelnummerHash %}class="text-info fs-5"{% endif %}>{{ place }}</td>
                                        <td class="text-start">
                                            <div {% if entry.hash == matrikelnummerHash %}class="d-inline-block fs-5"{% endif %}>
                                                {% if place == 1 %}
                                                    <span style="color: #ffd700"><i class="fa-solid fa-crown"></i></span>
                                                {% endif %}
                                                {% if place == 2 %}
                                                    <span style="color: #c0c0c0"><i class="fa-solid fa-crown"></i></span>
                                                {% endif %}
                                                {% if place == 3 %}
                                                    <span style="color: #bf8970"><i class="fa-solid fa-crown"></i></span>
                                                {% endif %}
                                                <span {% if entry.hash == matrikelnummerHash %}class="text-info"{% endif %}>
                                                {{ entry.matrikelnumber }}
                                                {% if entry.hash == matrikelnummerHash %}
                                                    <i class="fa-regular fa-circle-user"></i>
                                                {% endif %}
                                                </span>
                                            </div>
                                        </td>
                                        <td {% if entry.hash == matrikelnummerHash %}class="text-info fs-5"{% endif %}>{{ entry.score }}</td>
                                    {% else %}
                                        <td>{{ place }}</td>
                                        <td class="text-start">
                                            {% if place == 1 %}
                                                <span style="color: #ffd700"><i class="fa-solid fa-crown"></i></span>
                                            {% endif %}
                                            {% if place == 2 %}
                                                <span style="color: #c0c0c0"><i class="fa-solid fa-crown"></i></span>
                                            {% endif %}
                                            {% if place == 3 %}
                                                <span style="color: #bf8970"><i class="fa-solid fa-crown"></i></span>
                                            {% endif %}
                                            {{ entry.matrikelnumber }}
                                        </td>
                                        <td>{{ entry.score }}</td>
                                    {% endif %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
            <a href="/dashboard" type="button" class="btn btn-secondary bg-gradient mt-3"><i class="fa-solid fa-table-columns"></i> Zurück zum Dashboard</a>
        </div>
    </div>
</div>
{% endblock %}
