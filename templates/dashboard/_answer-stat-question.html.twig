<div class="answer-stat-question" id="answer-stat-question-{{ entry.question.id }}">
    <div class="text-center position-relative rounded bg-gradient p-2 mb-3
        {% if entry.percent >= 70 %}
            bg-success-subtle text-success-emphasis border border-success-subtle
        {% elseif entry.percent >= 40 %}
            bg-warning-subtle text-warning-emphasis border border-warning-subtle
        {% else %}
            bg-danger-subtle text-danger-emphasis border border-danger-subtle
        {% endif %}
    ">
        <h3>Frage {{ index + 1 }}</h3>
        <div class="position-absolute top-0 end-0 pe-2 pt-1 text-end lh-sm">
            <span class="fs-5 fw-bold d-block">
                <i class="fa-regular fa-circle-check"></i> {{ entry.rightCount }}/{{ entry.playerCount }}
            </span>
            <span class="fs-6 fw-bold d-block">
                {{ entry.percent|round }}%
            </span>
        </div>
        {% if entry.question.text|trim is not empty %}
            <h4 class="mb-3 mt-3">{{ entry.question.text }}</h4>
        {% endif %}
        {% if entry.question.image %}
            {% set questionImageSrc = versioned_image_url(entry.question.image, quiz) %}
            <img src="{{ questionImageSrc }}" alt="Fragebild {{ index + 1 }}" class="img-fluid rounded mb-2" style="max-height: 180px; width: auto; object-fit: contain;">
        {% endif %}
    </div>
    <ul class="list-group mb-3">
        <li class="list-group-item position-relative question-stats-li fs-5 pt-2 pb-2 {% if entry.answerOne.object.isCorrect %}text-success{% endif %}">
            <span class="question__letter question__letter--statistics bg-dark text-light border">A</span>
            {% if entry.answerOne.object.text|trim is not empty %}
                {{ entry.answerOne.object.text }}
            {% endif %}
            {% if entry.answerOne.object.image %}
                {% set imageSrcA = versioned_image_url(entry.answerOne.object.image, quiz) %}
                <div class="{% if entry.answerOne.object.text|trim is not empty %}mt-2{% endif %}">
                    <img src="{{ imageSrcA }}" alt="Antwortbild A" class="img-fluid rounded answer-result-image {% if entry.answerOne.object.isCorrect %}answer-result-image--correct{% endif %}">
                </div>
            {% endif %}
            <span style="min-width: 50px" class="position-absolute end-0 border-start p-2 top-0 bottom-0">{{ entry.answerOne.cnt}}</span>
        </li>
        <li class="list-group-item position-relative question-stats-li fs-5 pt-2 pb-2 {% if entry.answerTwo.object.isCorrect %}text-success{% endif %}">
            <span class="question__letter question__letter--statistics bg-dark text-light border">B</span>
            {% if entry.answerTwo.object.text|trim is not empty %}
                {{ entry.answerTwo.object.text }}
            {% endif %}
            {% if entry.answerTwo.object.image %}
                {% set imageSrcB = versioned_image_url(entry.answerTwo.object.image, quiz) %}
                <div class="{% if entry.answerTwo.object.text|trim is not empty %}mt-2{% endif %}">
                    <img src="{{ imageSrcB }}" alt="Antwortbild B" class="img-fluid rounded answer-result-image {% if entry.answerTwo.object.isCorrect %}answer-result-image--correct{% endif %}">
                </div>
            {% endif %}
            <span style="min-width: 50px" class="position-absolute end-0 border-start p-2 top-0 bottom-0">{{ entry.answerTwo.cnt}}</span>
        </li>
        <li class="list-group-item position-relative question-stats-li fs-5 pt-2 pb-2 {% if entry.answerThree.object.isCorrect %}text-success{% endif %}">
            <span class="question__letter question__letter--statistics bg-dark text-light border">C</span>
            {% if entry.answerThree.object.text|trim is not empty %}
                {{ entry.answerThree.object.text }}
            {% endif %}
            {% if entry.answerThree.object.image %}
                {% set imageSrcC = versioned_image_url(entry.answerThree.object.image, quiz) %}
                <div class="{% if entry.answerThree.object.text|trim is not empty %}mt-2{% endif %}">
                    <img src="{{ imageSrcC }}" alt="Antwortbild C" class="img-fluid rounded answer-result-image {% if entry.answerThree.object.isCorrect %}answer-result-image--correct{% endif %}">
                </div>
            {% endif %}
            <span style="min-width: 50px" class="position-absolute end-0 border-start p-2 top-0 bottom-0">{{ entry.answerThree.cnt}}</span>
        </li>
        <li class="list-group-item position-relative question-stats-li fs-5 pt-2 pb-2 {% if entry.answerFour.object.isCorrect %}text-success{% endif %}">
            <span class="question__letter question__letter--statistics bg-dark text-light border">D</span>
            {% if entry.answerFour.object.text|trim is not empty %}
                {{ entry.answerFour.object.text }}
            {% endif %}
            {% if entry.answerFour.object.image %}
                {% set imageSrcD = versioned_image_url(entry.answerFour.object.image, quiz) %}
                <div class="{% if entry.answerFour.object.text|trim is not empty %}mt-2{% endif %}">
                    <img src="{{ imageSrcD }}" alt="Antwortbild D" class="img-fluid rounded answer-result-image {% if entry.answerFour.object.isCorrect %}answer-result-image--correct{% endif %}">
                </div>
            {% endif %}
            <span style="min-width: 50px" class="position-absolute end-0 border-start p-2 top-0 bottom-0">{{ entry.answerFour.cnt}}</span>
        </li>
    </ul>
</div>
